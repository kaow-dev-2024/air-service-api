  "remark_th": "สคริปต์หลัก: dev=รันโหมดพัฒนา, start=รันเซิร์ฟเวอร์, migrate=รันไมเกรชัน, seed=รันข้อมูลตั้งต้น, test:integration=ทดสอบ API แบบรวม",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
